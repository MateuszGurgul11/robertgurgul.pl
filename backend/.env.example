# --- Produkcja (Render) ---
FIREBASE_PROJECT_ID=your-firebase-project-id
# Cała zawartość pliku service-account JSON (jedna linia) LUB ścieżka do pliku .json
# (np. ./twoj-projekt-firebase-adminsdk.json w katalogu backend/).
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}
FIREBASE_STORAGE_BUCKET=your-project.appspot.com

# E-mail powiadomień z formularza kontaktowego (Resend — https://resend.com).
# Bez tych dwóch zmiennych wiadomości są zapisywane w Firestore, ale e-mail nie jest wysyłany.
RESEND_API_KEY=
CONTACT_EMAIL_TO=
CONTACT_EMAIL_FROM=Formularz kontaktowy <onboarding@resend.dev>

# Domeny frontendu, które mogą wołać to API (rozdzielone przecinkami).
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://robertgurgul.pl

# --- Lokalny development z Firebase Local Emulator Suite ---
# Odkomentuj poniższe i NIE ustawiaj FIREBASE_SERVICE_ACCOUNT_JSON, żeby działać
# wyłącznie na emulatorach (zob. /firebase oraz README).
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
