rules_version = '2';

// Firestore is accessed exclusively by the backend via the Admin SDK, which
// bypasses these rules entirely. No client (browser) ever talks to Firestore
// directly, so this is intentionally locked down as defense in depth.
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
